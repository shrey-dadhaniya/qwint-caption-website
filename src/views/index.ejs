                    <% const pricingPackages=Array.isArray(products) ? products : []; %>
                        <div class="pricing-grid">
                            <% pricingPackages.forEach(function(pack, index) { %>
                                <% const isPopular=String(pack.tagline || '' ).toUpperCase().includes('POPULAR'); %>
                                    <div class="pricing-card <%= isPopular ? 'pricing-card-popular' : '' %>">
                                        <% if (isPopular) { %>
                                            <div class="plan-popular-badge">
                                                <%= pack.tagline %>
                                            </div>
                                            <% } %>
                                                <div class="plan-name">
                                                    <%= pack.name %>
                                                </div>
                                                <div class="plan-price">₹<%= pack.amount_inr %>
                                                </div>
                                                <div class="plan-credits">
                                                    <%= pack.credits_minutes %> minutes of captions
                                                </div>
                                                <ul class="plan-features">
                                                    <% (pack.includes || []).forEach(function(benefit) { %>
                                                        <li>✓ <%= benefit %>
                                                        </li>
                                                        <% }); %>
                                                </ul>
                                                <button
                                                    class="btn <%= isPopular ? 'btn-primary' : 'btn-outline' %> btn-full"
                                                    onclick="handlePackageCheckout('<%= pack.id %>')"
                                                    id="buy-<%= pack.id %>">
                                                    Buy <%= pack.name %>
                                                </button>
                                    </div>
                                    <% }); %>
                        </div>
                        <div class="pricing-note">
