                                            <stop stop-color="#6A00FF" />
                                            <stop offset="1" stop-color="#A259FF" />
                                        </linearGradient>
                                    </defs>
                                </svg>
                            </div>
                            <h3>AI Instantly Creates Your Captions</h3>
                            <p>Our AI transcribes the audio and places accurate captions directly on your timeline.
                                Edit, style,
                                and export.</p>
                        </div>
                    </div>
                </div>
