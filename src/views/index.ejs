              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- CTA Banner -->
    <section id="cta-banner" aria-label="Final call to action">
      <div class="container">
        <div class="cta-inner reveal">
          <h2>Stop typing subtitles <br>manually.</h2>
          <p>Generate them directly inside Premiere Pro.</p>
          <div class="cta-actions">
            <button onclick="handleCheckout('<%= paymentLinkIdStarter %>')" class="btn btn-outline-white btn-xl"
              id="cta-buy-btn" aria-label="Get the Starter Pack for ₹ 249" style="border:none; cursor:pointer;">
              <img src="assets/icons/cart.svg" alt=""
                style="width: 18px; height: 18px; filter: brightness(0) invert(1);">
              Get Starter Pack ₹ 249
            </button>
            <a href="#demo" class="btn btn-outline-white btn-xl" id="cta-demo-btn">Watch Demo First</a>
          </div>
          <p class="cta-trust">✓ Stripe secure checkout &nbsp;·&nbsp; ✓ Instant delivery
          </p>
        </div>
      </div>
    </section>

    <!-- ── Footer ───────────────────────────────────────────────── -->
    <%- include('partials/footer') %>

      <script>
        async function handleCheckout(paymentLinkId) {
          if (!paymentLinkId || paymentLinkId === '#') {
            showToast("Payment link not configured.", true);
            return;
          }
          showToast("Preparing checkout...", false);
          try {
            const res = await fetch('/api/checkout', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ paymentLinkId })
            });
            const data = await res.json();
            if (data.url) {
              window.location.href = data.url;
            } else {
              showToast(data.error || "Could not start checkout", true);
            }
          } catch (e) {
            showToast("Network error. Try again.", true);
          }
        }
      </script>

</body>

