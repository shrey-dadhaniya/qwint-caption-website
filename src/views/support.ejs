<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Support – Qwint Caption by Qwintsoft LLP</title>
    <meta name="description"
        content="Get help with Qwint Caption. Browse FAQs, troubleshooting guides, and contact our support team." />
    <meta name="robots" content="index, follow" />
    <link rel="stylesheet" href="assets/css/style.css" />
    <link rel="icon" type="image/svg+xml" href="assets/images/logo.svg" />
    <style>
        .support-hero {
            padding: 8rem 0 4rem;
            text-align: center;
            background: linear-gradient(135deg, #f7f8fc 0%, #eef2ff 100%);
            border-bottom: 1px solid var(--clr-border);
        }

        .support-hero h1 {
            font-family: var(--font-head);
            font-size: clamp(2rem, 4.5vw, 3rem);
            font-weight: 800;
            letter-spacing: -.03em;
            margin-bottom: .75rem;
        }

        .support-hero p {
            color: var(--clr-text-2);
            font-size: 1.05rem;
            max-width: 500px;
            margin-inline: auto;
        }

        .support-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 1.5rem;
            margin-top: -3rem;
        }

        .support-card {
            background: var(--clr-bg);
            border: 1px solid var(--clr-border);
            border-radius: var(--radius-md);
            padding: 2rem;
            box-shadow: var(--shadow-md);
            transition: all .3s var(--ease);
            text-align: center;
            cursor: pointer;
        }

        .support-card:hover {
            border-color: var(--clr-primary);
            box-shadow: var(--shadow-lg);
            transform: translateY(-4px);
        }

        .sc-icon {
            font-size: 2.5rem;
            margin-bottom: 1rem;
            display: block;
        }

        .support-card h3 {
            font-size: 1.05rem;
            font-weight: 700;
            margin-bottom: .4rem;
        }

        .support-card p {
            font-size: .87rem;
            color: var(--clr-text-2);
            line-height: 1.65;
            margin-bottom: 1rem;
        }

        .support-card .sc-link {
            display: inline-flex;
            align-items: center;
            gap: .3rem;
            font-size: .85rem;
            font-weight: 600;
            color: var(--clr-primary);
        }

        .support-content {
            padding-block: 4rem;
        }

        .support-section {
            max-width: 760px;
            margin-inline: auto;
            margin-bottom: 3rem;
        }

        .support-section h2 {
            font-size: 1.3rem;
            font-weight: 800;
            margin-bottom: 1.2rem;
            letter-spacing: -.02em;
        }

        .troubleshoot-item {
            border: 1px solid var(--clr-border);
            border-radius: var(--radius-md);
            margin-bottom: .75rem;
            overflow: hidden;
        }

        .troubleshoot-trigger {
            width: 100%;
            padding: 1.1rem 1.3rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            text-align: left;
            font-size: .9rem;
            font-weight: 600;
            color: var(--clr-text);
            background: var(--clr-bg);
            cursor: pointer;
        }

        .troubleshoot-item.open .troubleshoot-trigger {
            color: var(--clr-primary);
            background: var(--clr-primary-lt);
        }

        .troubleshoot-body {
            max-height: 0;
            overflow: hidden;
            transition: max-height .4s var(--ease);
        }

        .troubleshoot-item.open .troubleshoot-body {
            max-height: 400px;
        }

        .troubleshoot-body-inner {
            padding: .5rem 1.3rem 1.1rem;
            font-size: .87rem;
            color: var(--clr-text-2);
            line-height: 1.7;
        }

        .troubleshoot-body-inner ol {
            padding-left: 1.3rem;
        }

        .troubleshoot-body-inner li {
            margin-bottom: .3rem;
        }

        .contact-form {
            background: var(--clr-bg-alt);
            border: 1px solid var(--clr-border);
            border-radius: var(--radius-lg);
            padding: 2.5rem;
        }

        .form-group {
            margin-bottom: 1.2rem;
        }

        .form-group label {
            display: block;
            font-size: .85rem;
            font-weight: 600;
            margin-bottom: .4rem;
            color: var(--clr-text);
        }

        .form-group input,
        .form-group select,
        .form-group textarea {
            width: 100%;
            padding: .75rem 1rem;
            border: 1.5px solid var(--clr-border);
            border-radius: var(--radius-sm);
            font-size: .9rem;
            font-family: var(--font-body);
            color: var(--clr-text);
            background: var(--clr-bg);
            transition: border-color .2s;
            outline: none;
        }

        .form-group input:focus,
        .form-group select:focus,
        .form-group textarea:focus {
            border-color: var(--clr-primary);
            box-shadow: 0 0 0 3px rgba(79, 70, 229, .12);
        }

        .form-group textarea {
            min-height: 120px;
            resize: vertical;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 1rem;
        }

        .form-note {
            font-size: .78rem;
            color: var(--clr-text-3);
            margin-top: .3rem;
        }

        @media (max-width: 560px) {
            .form-row {
                grid-template-columns: 1fr;
            }

            .support-grid {
                margin-top: 2rem;
            }
        }
    </style>
    <%- include('partials/meta-pixel') %>
</head>

<body>
    <%- include('partials/navbar') %>

        <header class="support-hero" aria-labelledby="support-heading">
            <div class="container">
                <span class="badge" style="margin-bottom:1rem">🛟 Support Center</span>
                <h1 id="support-heading">How can we <span class="grad-text">help you?</span></h1>
                <p>Search our guides, troubleshoot common issues, or reach out to our team directly.</p>
            </div>
        </header>

        <main>
            <div class="container">
                <!-- Support channels -->
                <div class="support-grid" style="margin-top:3rem">
                    <div class="support-card"
                        onclick="document.getElementById('contact-form').scrollIntoView({behavior:'smooth'})">
                        <span class="sc-icon" aria-hidden="true">✉️</span>
                        <h3>Email Support</h3>
                        <p>Our team typically responds within 1–2 business days. Include your order ID for faster help.
                        </p>
                        <a href="mailto:support@qwintsoft.com" class="sc-link">support@qwintsoft.com →</a>
                    </div>
                    <div class="support-card"
                        onclick="document.getElementById('troubleshoot').scrollIntoView({behavior:'smooth'})">
                        <span class="sc-icon" aria-hidden="true">🔧</span>
                        <h3>Troubleshooting Guides</h3>
                        <p>Step-by-step solutions to the most common issues. Resolve most problems in minutes.</p>
                        <span class="sc-link">Browse guides →</span>
                    </div>
                    <div class="support-card" onclick="window.location.href='/#faq'">
                        <span class="sc-icon" aria-hidden="true">❓</span>
                        <h3>FAQ</h3>
                        <p>Answers to frequently asked questions about licensing, credits, compatibility, and more.</p>
                        <span class="sc-link">View FAQ →</span>
                    </div>
                </div>

                <div class="support-content">

                    <!-- Troubleshooting -->
                    <div class="support-section" id="troubleshoot">
                        <h2>Common Issues & Solutions</h2>

                        <div class="troubleshoot-item">
                            <button class="troubleshoot-trigger" aria-expanded="false">
                                Plugin not showing in Premiere Pro extensions menu
                                <span aria-hidden="true">+</span>
                            </button>
                            <div class="troubleshoot-body">
                                <div class="troubleshoot-body-inner">
                                    <ol>
                                        <li>Ensure Adobe Premiere Pro is fully closed before installation.</li>
                                        <li>Right-click the installer and select "Run as Administrator."</li>
                                        <li>After installation, relaunch Premiere Pro and check Window → Extensions →
                                            Qwint
                                            Caption.</li>
                                        <li>If still not visible, go to Window → Workspaces → Reset to Saved Layout and
                                            try
                                            again.</li>
                                        <li>Check that your Premiere Pro version is 2022 or later.</li>
                                    </ol>
                                </div>
                            </div>
                        </div>

                        <div class="troubleshoot-item">
                            <button class="troubleshoot-trigger" aria-expanded="false">
                                License key activation fails or shows "Invalid key"
                                <span aria-hidden="true">+</span>
                            </button>
                            <div class="troubleshoot-body">
                                <div class="troubleshoot-body-inner">
                                    <ol>
                                        <li>Double-check for leading/trailing spaces when pasting your key.</li>
                                        <li>Ensure you have an active internet connection.</li>
                                        <li>If you've already activated on 2 machines, deactivate one before activating
                                            on a
                                            new machine.</li>
                                        <li>Contact support with your order ID if the issue persists we can reset your
                                            activation.</li>
                                    </ol>
                                </div>
                            </div>
                        </div>

                        <div class="troubleshoot-item">
                            <button class="troubleshoot-trigger" aria-expanded="false">
                                Caption generation is very slow or times out
                                <span aria-hidden="true">+</span>
                            </button>
                            <div class="troubleshoot-body">
                                <div class="troubleshoot-body-inner">
                                    <ol>
                                        <li>Check your internet connection speed. AI transcription requires a stable
                                            internet connection.</li>
                                        <li>For sequences longer than 30 minutes, process in smaller segments.</li>
                                        <li>Ensure Premiere Pro is not rendering or exporting simultaneously.</li>
                                        <li>Check our status page for any service outages.</li>
                                    </ol>
                                </div>
                            </div>
                        </div>

                        <div class="troubleshoot-item">
                            <button class="troubleshoot-trigger" aria-expanded="false">
                                Captions appear out of sync with the video
                                <span aria-hidden="true">+</span>
                            </button>
                            <div class="troubleshoot-body">
                                <div class="troubleshoot-body-inner">
                                    <ol>
                                        <li>Ensure your sequence settings match your original footage frame rate.</li>
                                        <li>If working with mixed-frame-rate footage, standardize the sequence first.
                                        </li>
                                        <li>Use the "Manual Sync" adjustment in the Qwint Caption panel to offset all
                                            captions by a fixed amount.</li>
                                        <li>Re-generate captions from the specific problematic section.</li>
                                    </ol>
                                </div>
                            </div>
                        </div>

                        <div class="troubleshoot-item">
                            <button class="troubleshoot-trigger" aria-expanded="false">
                                I accidentally used all my credits can I get a refund?
                                <span aria-hidden="true">+</span>
                            </button>
                            <div class="troubleshoot-body">
                                <div class="troubleshoot-body-inner">
                                    <p>Credits are consumed once used during AI transcription and cannot be refunded
                                        once
                                        processed. However, if credits were consumed due to a verified Software error on
                                        our
                                        end (e.g., a failed transcription that still deducted credits), please contact
                                        us
                                        and we will restore the credits.</p>
                                </div>
                            </div>
                        </div>

                    </div>

                    <!-- Contact Form -->
                    <div class="support-section" id="contact-form">
                        <h2>Contact Support</h2>
                        <div class="contact-form">
                            <form id="support-form" novalidate onsubmit="handleSupportForm(event)"
                                aria-label="Support contact form">
                                <div class="form-row">
                                    <div class="form-group">
                                        <label for="support-name">Full Name *</label>
                                        <input type="text" id="support-name" name="name" required
                                            placeholder="Your name" autocomplete="name" />
                                    </div>
                                    <div class="form-group">
                                        <label for="support-email">Email Address *</label>
                                        <input type="email" id="support-email" name="email" required
                                            placeholder="your@email.com" autocomplete="email" />
                                    </div>
                                </div>
                                <div class="form-group">
                                    <label for="support-order">Order / Transaction ID (optional)</label>
                                    <input type="text" id="support-order" name="order" placeholder="e.g. pi_3P..." />
                                    <p class="form-note">Found in your Stripe receipt email</p>
                                </div>
                                <div class="form-group">
                                    <label for="support-category">Issue Category *</label>
                                    <select id="support-category" name="category" required>
                                        <option value="" disabled selected>Select a category…</option>
                                        <option value="installation">Installation / Setup</option>
                                        <option value="activation">License Activation</option>
                                        <option value="credits">Credits & Billing</option>
                                        <option value="captions">Caption Generation</option>
                                        <option value="export">Export / File Format</option>
                                        <option value="refund">Refund Request</option>
                                        <option value="other">Other</option>
                                    </select>
                                </div>
                                <div class="form-group">
                                    <label for="support-msg">Describe your issue *</label>
                                    <textarea id="support-msg" name="message" required
                                        placeholder="Please describe your issue in detail. Include your OS, Premiere Pro version, and any error messages you see."></textarea>
                                </div>
                                <div class="form-group" style="display:flex;align-items:flex-start;gap:.5rem">
                                    <input type="checkbox" id="support-consent" name="consent" required
                                        style="width:auto;margin-top:3px;flex-shrink:0" />
                                    <label for="support-consent"
                                        style="font-size:.82rem;color:var(--clr-text-2);font-weight:400">
                                        I agree to Qwintsoft LLP processing my data to respond to this support request,
                                        in
                                        accordance with the <a href="/privacy" style="color:var(--clr-primary)">Privacy
                                            Policy</a>.
                                    </label>
                                </div>
                                <button type="submit" class="btn btn-primary btn-lg" id="support-submit">
                                    Send Support Request
                                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                                        stroke-width="2" aria-hidden="true">
                                        <line x1="22" y1="2" x2="11" y2="13" />
                                        <polygon points="22 2 15 22 11 13 2 9 22 2" />
                                    </svg>
                                </button>
                                <div id="form-success"
                                    style="display:none;margin-top:1rem;padding:1rem;background:#ecfdf5;border:1px solid #10b981;border-radius:var(--radius-sm);font-size:.88rem;color:#065f46">
                                    ✓ Your message has been sent! We'll get back to you within 1–2 business days.
                                </div>
                                <div id="form-error"
                                    style="display:none;margin-top:1rem;padding:1rem;background:#fef2f2;border:1px solid #ef4444;border-radius:var(--radius-sm);font-size:.88rem;color:#7f1d1d">
                                    Please fill in all required fields correctly before submitting.
                                </div>
                            </form>
                        </div>
                    </div>

                </div>
            </div>
        </main>

        <%- include('partials/footer') %>

            <script>
                // Troubleshoot accordion
                document.querySelectorAll('.troubleshoot-trigger').forEach(trigger => {
                    trigger.addEventListener('click', () => {
                        const item = trigger.closest('.troubleshoot-item');
                        const isOpen = item.classList.contains('open');
                        document.querySelectorAll('.troubleshoot-item.open').forEach(i => {
                            i.classList.remove('open');
                            i.querySelector('.troubleshoot-trigger').setAttribute('aria-expanded', 'false');
                        });
                        if (!isOpen) {
                            item.classList.add('open');
                            trigger.setAttribute('aria-expanded', 'true');
                        }
                    });
                });

                // Support form validation
                function handleSupportForm(e) {
                    e.preventDefault();
                    const form = e.target;
                    const name = form.name.value.trim();
                    const email = form.email.value.trim();
                    const cat = form.category.value;
                    const msg = form.message.value.trim();
                    const consent = form.consent.checked;
                    const errEl = document.getElementById('form-error');
                    const sucEl = document.getElementById('form-success');

                    errEl.style.display = 'none';
                    sucEl.style.display = 'none';

                    // Basic validation
                    const emailRe = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
                    if (!name || !email || !cat || !msg || !consent || !emailRe.test(email)) {
                        errEl.style.display = 'block';
                        return;
                    }

                    // Simulate form submission (replace with actual endpoint)
                    const submitBtn = document.getElementById('support-submit');
                    submitBtn.textContent = 'Sending…';
                    submitBtn.disabled = true;

                    setTimeout(() => {
                        sucEl.style.display = 'block';
                        form.reset();
                        submitBtn.textContent = 'Send Support Request';
                        submitBtn.disabled = false;
                    }, 1000);
                }


            </script>
</body>

</html>