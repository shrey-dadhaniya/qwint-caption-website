<!DOCTYPE html>
<html lang="en">

<%- include('partials/landing/head', {
    pageTitle: 'Payment Successful — Qwint Caption',
    pageDescription: 'Payment confirmation and secure plugin download for Qwint Caption.',
    robots: 'noindex, nofollow',
    extraCssPath: '/assets/css/landing-pages.css'
}) %>

<body>

    <%- include('partials/landing/navbar') %>

        <main class="success-main">
            <div class="card success-card">
                <!-- Success icon -->
                <div class="success-badge">
                    <svg fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                    </svg>
                </div>

                <p class="success-headline-badge">Order Complete</p>
                <h1 class="payment-success-title">Payment Confirmed</h1>
                <p class="subtitle" id="sub-status">Setting up your plugin download. This only takes a few seconds.
                </p>

                <!-- Spinner shown while backend fulfillment runs -->
                <div id="loading-wrap" class="success-loading-wrap">
                    <div class="spinner-wrap">
                        <div class="spinner"></div>
                        <div class="spinner-label">Preparing your plugin</div>
                    </div>
                </div>

                <!-- Order Details -->
                <div class="order-details success-order-details">
                    <div class="order-title">Order Details</div>

                    <% if (orderDetails.phone) { %>
                        <div class="order-row">
                            <span class="order-key">Phone</span>
                            <span class="order-val" id="od-phone">
                                <%= orderDetails.phone %>
                            </span>
                        </div>
                        <% } %>

                            <% if (orderDetails.amount) { %>
                                <div class="order-row">
                                    <span class="order-key">Amount Paid</span>
                                    <span class="order-val">
                                        <%= orderDetails.currency %> ₹<%= orderDetails.amount %>
                                    </span>
                                </div>
                                <% } %>

                                    <div class="order-row">
                                        <span class="order-key">Order ID</span>
                                        <span class="order-val mono" id="od-order-id">
                                            <%= orderDetails.order_id %>
                                        </span>
                                    </div>

                                    <% if (orderDetails.payment_id) { %>
                                        <div class="order-row">
                                            <span class="order-key">Payment ID</span>
                                            <span class="order-val mono" id="od-payment-id">
                                                <%= orderDetails.payment_id %>
                                            </span>
                                        </div>
                                        <% } %>

                                    <% if (orderDetails.customer_id) { %>
                                        <div class="order-row">
                                            <span class="order-key">Customer ID</span>
                                            <span class="order-val mono">
                                                <%= orderDetails.customer_id %>
                                            </span>
                                        </div>
                                        <% } %>
                </div>

                <!-- Support note -->
                <div class="support-note success-support-note">
                    <span class="support-note-icon">🛟</span>
                    <p><strong>Need help?</strong> Email support with your <strong>Order ID</strong> and <strong>Phone</strong>.
                        We usually respond within 24 hours.</p>
                </div>

                <!-- Actions (shown when key is ready) -->
                <div class="actions success-actions" id="actions">
                    <!-- Download button — populated dynamically from /api/check-key pluginUrl -->
                    <a href="#" class="btn btn-outline btn-secondary-outline btn-download-primary" id="download-btn"
                        style="display:none;"
                        download>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2">
                            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
                            <polyline points="7 10 12 15 17 10"></polyline>
                            <line x1="12" y1="15" x2="12" y2="3"></line>
                        </svg>
                        Download Plugin
                    </a>
                </div>
            </div>
        </main>

        <%- include('partials/landing/footer') %>
        <script src="/assets/js/landing.js"></script>

            <script>
                const orderId = "<%= order_id %>";

                // ── Polling for key ──
                let pollAttempts = 0;
                const MAX_POLL_ATTEMPTS = 28; // ~70 seconds before giving up

                async function poll() {
                    pollAttempts++;
                    try {
                        const res = await fetch(`/api/check-key?order_id=${orderId}`);
                        const data = await res.json();

                        if (data.status === 'ready') {
                            document.getElementById('sub-status').textContent = 'Your plugin is ready to download!';

                            if (data.key) localStorage.setItem('qwint_litellm_key', data.key);

                            // Hide spinner
                            document.getElementById('loading-wrap').style.display = 'none';

                            // Wire up plugin download button
                            const dlBtn = document.getElementById('download-btn');
                            if (data.pluginUrl) {
                                dlBtn.href = data.pluginUrl;
                                dlBtn.style.display = 'flex';
                            }

                            document.getElementById('actions').classList.add('visible');
                        } else if (data.status === 'error') {
                            document.getElementById('sub-status').textContent = data.message || 'Payment completed, but setup is delayed. Please contact support.';
                            document.getElementById('loading-wrap').style.display = 'none';
                            document.getElementById('actions').classList.add('visible');
                        } else if (pollAttempts >= MAX_POLL_ATTEMPTS) {
                            // Give up after ~70s — show support message
                            document.getElementById('sub-status').textContent =
                                'Setup is taking longer than expected. Please email support with your Order ID — we\'ll sort it out quickly.';
                            document.getElementById('loading-wrap').style.display = 'none';
                            document.getElementById('actions').classList.add('visible');
                        } else {
                            setTimeout(poll, 2500);
                        }
                    } catch (e) {
                        if (pollAttempts >= MAX_POLL_ATTEMPTS) {
                            document.getElementById('sub-status').textContent =
                                'Setup is taking longer than expected. Please email support with your Order ID.';
                            document.getElementById('loading-wrap').style.display = 'none';
                            document.getElementById('actions').classList.add('visible');
                        } else {
                            setTimeout(poll, 5000);
                        }
                    }
                }

                poll();
            </script>
</body>

</html>
