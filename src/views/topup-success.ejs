<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <title>Payment Successful - Qwint Caption</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/assets/css/style.css" />
    <style>
        body {
            background-color: var(--clr-bg);
            color: var(--clr-text);
            font-family: inherit;
        }

        .success-container {
            max-width: 600px;
            margin: 100px auto;
            text-align: center;
            padding: 40px;
            background: var(--clr-bg-alt);
            border-radius: 16px;
            border: 1px solid var(--clr-border);
        }

        .check-icon {
            font-size: 64px;
            color: var(--clr-success);
            margin-bottom: 20px;
        }
    </style>
    <%- include('partials/meta-pixel') %>
</head>

<body>
    <%- include('partials/navbar') %>

        <main style="min-height: 80vh; display: flex; align-items: center; justify-content: center;">
            <div class="success-container">
                <div class="check-icon">✓</div>
                <h2>Payment Successful</h2>
                <p style="margin-top: 20px; font-size: 1.1rem; color: var(--clr-text-2);">
                    Your credit will be updated in 5 minutes.
                </p>
                <a href="/" class="btn btn-primary" style="margin-top: 30px; display: inline-flex;">Return to Home</a>
            </div>
        </main>

        <%- include('partials/footer') %>
</body>

</html>