<!DOCTYPE html>
<html lang="en">

<%- include('partials/landing/head', {
    pageTitle: 'Top-up - Qwint Caption',
    pageDescription: 'Top up your Qwint Caption credits and continue generating captions.',
    robots: 'noindex, nofollow',
    extraCssPath: '/assets/css/landing-pages.css'
}) %>

<body>

  <!-- ── Navigation ──────────────────────────────────────────── -->
  <%- include('partials/landing/navbar') %>

    <!-- ── Main Topup Content ──────────────────────────────────── -->
    <section id="topup-section" aria-labelledby="topup-heading">
      <div class="container">

        <!-- Lookup Section -->
        <div id="lookup-section" class="topup-lookup">
          <h2 id="topup-heading" style="margin-bottom: 10px;">Top-up Your Account</h2>
          <p style="color: var(--clr-text-2); margin-bottom: 25px;">Enter your LiteLLM key to retrieve your
            balance.</p>

          <input type="text" id="topup-query" placeholder="sk-..." onkeydown="if(event.key==='Enter') lookupCustomer()"
            autocomplete="off" spellcheck="false">

          <button class="btn btn-primary" id="lookup-submit" onclick="lookupCustomer()">
            Find Account
          </button>
        </div>

        <!-- Plans Section (Hidden by default) -->
        <div id="topup-plans" style="display: none;">

          <div id="customer-info">
            <h3 style="margin-bottom: 0.5rem; color: var(--clr-text);">Account Found</h3>
            <p style="color: var(--clr-text-2);">AI Credits: <span id="customer-balance"
                style="font-weight: bold; color: var(--clr-success); font-size: 1.2rem;">0 mins</span></p>

            <div style="margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--clr-border);">
              <p style="color: var(--clr-text-2); font-size: 0.9rem; margin-bottom: 1rem;">Lost your plugin? Redownload the latest version with your key pre-configured.</p>
              <button class="btn btn-outline" id="download-plugin-btn" onclick="downloadPlugin()" style="font-size: 0.9rem; padding: 0.6rem 1.2rem;">
                <img src="/assets/icons/download.svg" alt="" style="width: 16px; height: 16px; margin-right: 8px;">
                Download Latest Plugin (.zip)
              </button>
            </div>
          </div>

          <div class="section-header reveal" style="padding-top: 0; margin-top: 2rem;">
            <h2 style="font-size: 2rem;">Choose Top-up Pack</h2>
          </div>

          <%
            const starterPack = products.find((p) => p.id === 'starter') || products[0];
            const otherPacks = products.filter((p) => p.id !== starterPack.id);
          %>

          <div class="pricing-wrapper">
            <div class="reveal">
              <!-- Main attraction: Starter Pack -->
              <div class="pricing-main" style="margin-bottom: 2rem;">
                <div class="pricing-info">
                  <span class="pricing-badge"><%= starterPack.tagline || 'BEST ENTRY' %></span>
                  <div class="price-tag" style="margin-top:.8rem">
                    <span class="price-currency">₹</span>
                    <span class="price-amount"><%= starterPack.amount_inr %></span>
                    <span class="price-period">&nbsp;<%= starterPack.tax_note || '+ Tax' %></span>
                  </div>
                  <h3><%= starterPack.name %></h3>
                  <p><%= starterPack.description %></p>
                  <div class="price-includes">
                    <% (starterPack.includes || []).forEach(function(item) { %>
                      <div class="pi-item"><span class="check">✓</span> <%= item %></div>
                    <% }); %>
                  </div>
                </div>

                <div class="pricing-cta-area">
                  <div style="text-align:center">
                    <button onclick="handleTopupBtn('<%= starterPack.id %>')" class="btn btn-primary btn-xl"
                      style="width:100%; border:none; cursor:pointer;" id="topup-starter-btn">
                      <img src="/assets/icons/cart.svg" alt=""
                        style="width: 18px; height: 18px; filter: brightness(0) invert(1);">
                      Top-up ₹ <%= starterPack.amount_inr %>
                    </button>
                  </div>
                  <div class="stripe-badge" style="margin-top:1rem;">
                    <img src="/assets/icons/lock.svg" alt="" style="width: 14px; height: 14px;">
                    Secured by Razorpay
                  </div>
                </div>
              </div>

              <!-- Smaller Packs -->
              <div class="topup-grid"
                style="margin-bottom: 2rem; max-width: 900px; margin-left: auto; margin-right: auto;">
                <% otherPacks.forEach(function(pack) { %>
                  <div class="topup-card"
                    style="<%= pack.tagline === 'MOST POPULAR' ? 'border-color: var(--clr-primary); background: var(--clr-primary-lt);' : '' %>">
                    <% if (pack.tagline === 'MOST POPULAR') { %>
                      <div class="topup-popular-badge"><%= pack.tagline %></div>
                    <% } %>
                    <h4><%= pack.name %></h4>
                    <div class="topup-price">₹ <%= pack.amount_inr %> <span
                        style="font-size: 0.8rem; opacity: 0.7;"><%= pack.tax_note || '+ Tax' %></span></div>
                    <p><%= pack.description %></p>
                    <button onclick="handleTopupBtn('<%= pack.id %>')" class="btn btn-primary"
                      style="margin-top: 1rem; width: 100%; justify-content: center; font-size: 0.85rem; padding: 0.6rem; border-radius: var(--radius-md); border:none; cursor:pointer;"
                      id="topup-<%= pack.id %>-btn">Top-up Pack</button>
                  </div>
                <% }); %>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── Footer ───────────────────────────────────────────────── -->
    <%- include('partials/landing/footer') %>

      <script src="/assets/js/landing.js"></script>
      <script src="https://checkout.razorpay.com/v1/checkout.js"></script>
      <script>
        let currentCustomer = null;
        const fallbackRazorpayKeyId = "<%= razorpayKeyId %>";

        async function lookupCustomer() {
          const query = document.getElementById('topup-query').value.trim();
          const btn = document.getElementById('lookup-submit');

          if (!query) {
            showToast("Please enter your LiteLLM key", true);
            return;
          }

          btn.disabled = true;
          btn.textContent = 'Searching...';

          try {
            const res = await fetch('/api/topup-info', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ query })
            });
            const data = await res.json();

            if (data.error) {
              showToast(data.error, true);
            } else {
              currentCustomer = data;
              document.getElementById('customer-balance').innerText = data.available_budget + ' credits';
              document.getElementById('lookup-section').style.display = 'none';
              document.getElementById('topup-plans').style.display = 'block';
            }
          } catch (err) {
            showToast("Network error. Try again.", true);
          }

          btn.disabled = false;
          btn.textContent = 'Find Account';
        }

        async function verifyAndRedirect(razorpayResponse) {
          showToast("Verifying payment...", false);
          const verifyRes = await fetch('/api/payment/verify', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(razorpayResponse)
          });
          const verifyData = await verifyRes.json();

          if (!verifyRes.ok || !verifyData.ok || !verifyData.redirectUrl) {
            throw new Error(verifyData.error || 'Could not verify payment');
          }

          window.location.href = verifyData.redirectUrl;
        }

        function openRazorpayCheckout(data) {
          const checkout = data.checkout || {};
          const product = data.product || {};
          const keyId = data.razorpayKeyId || fallbackRazorpayKeyId;

          if (!keyId) {
            showToast("Razorpay key is not configured.", true);
            return;
          }
          if (typeof Razorpay === 'undefined') {
            showToast("Payment checkout failed to load. Refresh and retry.", true);
            return;
          }

          const options = {
            key: keyId,
            amount: data.order.amount,
            currency: data.order.currency,
            name: checkout.name || 'Qwint Caption',
            description: product.name || checkout.description || 'Top-up Credits',
            order_id: data.order.id,
            prefill: currentCustomer && currentCustomer.phone ? { contact: currentCustomer.phone } : undefined,
            notes: { product_id: product.id || '' },
            theme: { color: checkout.theme_color || '#4f46e5' },
            handler: async function (response) {
              try {
                await verifyAndRedirect(response);
              } catch (err) {
                showToast(err.message || "Payment verification failed.", true);
              }
            },
            modal: {
              ondismiss: function () {
                showToast("Payment was cancelled.", true);
              }
            }
          };

          const rzp = new Razorpay(options);
          rzp.on('payment.failed', function (event) {
            const reason = event && event.error && event.error.description
              ? event.error.description
              : "Payment failed. Please try again.";
            showToast(reason, true);
          });
          rzp.open();
        }

        async function handleTopupBtn(productId) {
          if (!currentCustomer || !currentCustomer.key) {
            showToast("Find your account before checkout.", true);
            return;
          }
          if (!productId) {
            showToast("Product is not configured.", true);
            return;
          }

          showToast("Opening secure checkout...", false);

          try {
            const checkoutReq = await fetch('/api/checkout-topup', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                productId: productId,
                key: currentCustomer.key
              })
            });

            const checkoutData = await checkoutReq.json();
            if (!checkoutReq.ok || checkoutData.error || !checkoutData.order) {
              showToast("Could not initiate checkout: " + (checkoutData.error || "Unknown"), true);
              return;
            }

            openRazorpayCheckout(checkoutData);
          } catch (e) {
            showToast("Network error. Try again.", true);
          }
        }

        async function downloadPlugin() {
          if (!currentCustomer || !currentCustomer.key) return;
          
          const btn = document.getElementById('download-plugin-btn');
          const originalContent = btn.innerHTML;
          
          btn.disabled = true;
          btn.innerHTML = 'Generating...';

          try {
            const res = await fetch('/api/generate-plugin', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ key: currentCustomer.key })
            });
            const data = await res.json();

            if (data.url) {
              const link = document.createElement('a');
              link.href = data.url;
              link.download = '';
              document.body.appendChild(link);
              link.click();
              document.body.removeChild(link);
              showToast("Download started", false);
            } else {
              showToast(data.error || "Failed to generate plugin", true);
            }
          } catch (err) {
            showToast("Network error. Try again.", true);
          }

          btn.disabled = false;
          btn.innerHTML = originalContent;
        }

        // Auto-lookup if 'key' query parameter is present
        document.addEventListener('DOMContentLoaded', () => {
          const urlParams = new URLSearchParams(window.location.search);
          const keyParam = urlParams.get('key');
          if (keyParam) {
            document.getElementById('topup-query').value = keyParam;
            lookupCustomer();

            // Remove the 'key' from the URL without reloading the page
            urlParams.delete('key');
            const newUrl = window.location.pathname + (urlParams.toString() ? '?' + urlParams.toString() : '');
            window.history.replaceState({}, document.title, newUrl);
          }
        });
      </script>
</body>

</html>
