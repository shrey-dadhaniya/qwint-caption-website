<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />

  <title>Top-up - Qwint Caption</title>
  <meta name="robots" content="noindex, nofollow" />

  <link rel="stylesheet" href="assets/css/style.css" />
  <link rel="icon" type="image/svg+xml" href="assets/images/logo.svg" />
  <style>
    /* Topup Form Specifics */
    #topup-section {
      padding-top: 150px;
      padding-bottom: 100px;
      min-height: 80vh;
    }

    .topup-lookup {
      max-width: 500px;
      margin: 0 auto;
      background: var(--clr-bg-alt);
      padding: 40px;
      border-radius: 16px;
      border: 1px solid var(--clr-border);
      text-align: center;
    }

    .topup-lookup input {
      width: 100%;
      padding: 14px 18px;
      background: var(--clr-bg);
      border: 1px solid var(--clr-border);
      border-radius: 8px;
      color: var(--clr-text);
      font-size: 1rem;
      font-family: inherit;
      outline: none;
      margin-bottom: 15px;
      transition: border-color 0.15s;
    }

    .topup-lookup input:focus {
      border-color: var(--clr-primary);
    }

    .topup-lookup .btn {
      width: 100%;
      justify-content: center;
    }

    #customer-info {
      text-align: center;
      margin-bottom: 30px;
      padding: 20px;
      background: var(--clr-bg-alt);
      border-radius: 10px;
      border: 1px solid var(--clr-primary);
      max-width: 800px;
      margin-inline: auto;
    }
  </style>
  <%- include('partials/meta-pixel') %>
</head>

<body>

  <!-- ── Navigation ──────────────────────────────────────────── -->
  <%- include('partials/navbar') %>

    <!-- ── Main Topup Content ──────────────────────────────────── -->
    <section id="topup-section" aria-labelledby="topup-heading">
      <div class="container">

        <!-- Lookup Section -->
        <div id="lookup-section" class="topup-lookup">
          <h2 id="topup-heading" style="margin-bottom: 10px;">Top-up Your Account</h2>
          <p style="color: var(--clr-text-2); margin-bottom: 25px;">Enter your LiteLLM key to retrieve your
            balance.</p>

          <input type="text" id="topup-query" placeholder="sk-..." onkeydown="if(event.key==='Enter') lookupCustomer()"
            autocomplete="off" spellcheck="false">

          <button class="btn btn-primary" id="lookup-submit" onclick="lookupCustomer()">
            Find Account
          </button>
        </div>

        <!-- Plans Section (Hidden by default) -->
        <div id="topup-plans" style="display: none;">

          <div id="customer-info">
            <h3 style="margin-bottom: 0.5rem; color: var(--clr-text);">Account Found</h3>
            <p style="color: var(--clr-text-2);">AI Credits: <span id="customer-balance"
                style="font-weight: bold; color: var(--clr-success); font-size: 1.2rem;">0 mins</span></p>

            <div style="margin-top: 1.5rem; padding-top: 1.5rem; border-top: 1px solid var(--clr-border);">
              <p style="color: var(--clr-text-2); font-size: 0.9rem; margin-bottom: 1rem;">Lost your plugin? Redownload the latest version with your key pre-configured.</p>
              <button class="btn btn-outline" id="download-plugin-btn" onclick="downloadPlugin()" style="font-size: 0.9rem; padding: 0.6rem 1.2rem;">
                <img src="assets/icons/download.svg" alt="" style="width: 16px; height: 16px; margin-right: 8px;">
                Download Latest Plugin (.zip)
              </button>
            </div>
          </div>

          <div class="section-header reveal" style="padding-top: 0; margin-top: 2rem;">
            <h2 style="font-size: 2rem;">Choose Top-up Pack</h2>
          </div>

          <div class="pricing-wrapper">
            <div class="reveal">
              <!-- Main attraction: Starter Pack -->
              <div class="pricing-main" style="margin-bottom: 2rem;">
                <div class="pricing-info">
                  <span class="pricing-badge">BEST ENTRY</span>
                  <div class="price-tag" style="margin-top:.8rem">
                    <span class="price-currency">₹</span>
                    <span class="price-amount">249</span>
                    <span class="price-period">&nbsp;+ Tax</span>
                  </div>
                  <h3>Starter Pack</h3>
                  <p>The perfect way to get started. Credits never expire.</p>
                  <div class="price-includes">
                    <div class="pi-item"><span class="check">✓</span> 60 Minutes Credits</div>
                    <div class="pi-item"><span class="check">✓</span> Credits never expire</div>
                  </div>
                </div>

                <div class="pricing-cta-area">
                  <div style="text-align:center">
                    <button onclick="handleTopupBtn('<%= paymentLinkIdStarter %>')" class="btn btn-primary btn-xl"
                      style="width:100%; border:none; cursor:pointer;" id="topup-starter-btn">
                      <img src="assets/icons/cart.svg" alt=""
                        style="width: 18px; height: 18px; filter: brightness(0) invert(1);">
                      Top-up ₹ 249
                    </button>
                  </div>
                  <div class="stripe-badge" style="margin-top:1rem;">
                    <img src="assets/icons/lock.svg" alt="" style="width: 14px; height: 14px;">
                    Secured by Stripe
                  </div>
                </div>
              </div>

              <!-- Smaller Packs -->
              <div class="topup-grid"
                style="margin-bottom: 2rem; max-width: 900px; margin-left: auto; margin-right: auto;">
                <div class="topup-card">
                  <h4>Lite Pack</h4>
                  <div class="topup-price">₹ 169 <span style="font-size: 0.8rem; opacity: 0.7;">+ Tax</span></div>
                  <p>30 minutes total</p>
                  <button onclick="handleTopupBtn('<%= paymentLinkIdLite %>')" class="btn btn-primary"
                    style="margin-top: 1rem; width: 100%; justify-content: center; font-size: 0.85rem; padding: 0.6rem; border-radius: var(--radius-md); border:none; cursor:pointer;"
                    id="topup-lite-btn">Top-up Pack</button>
                </div>
                <div class="topup-card" style="border-color: var(--clr-primary); background: var(--clr-primary-lt);">
                  <div class="topup-popular-badge">MOST POPULAR</div>
                  <h4>Creator Pack</h4>
                  <div class="topup-price">₹ 399 <span style="font-size: 0.8rem; opacity: 0.7;">+ Tax</span></div>
                  <p>180 mins total (165 + 15 Bonus)</p>
                  <button onclick="handleTopupBtn('<%= paymentLinkIdCreator %>')" class="btn btn-primary"
                    style="margin-top: 1rem; width: 100%; justify-content: center; font-size: 0.85rem; padding: 0.6rem; border-radius: var(--radius-md); border:none; cursor:pointer;"
                    id="topup-creator-btn">Top-up Pack</button>
                </div>
                <div class="topup-card">
                  <h4>Studio Pack</h4>
                  <div class="topup-price">₹ 499 <span style="font-size: 0.8rem; opacity: 0.7;">+ Tax</span></div>
                  <p>360 mins total (330 + 30 Bonus)</p>
                  <button onclick="handleTopupBtn('<%= paymentLinkIdStudio %>')" class="btn btn-primary"
                    style="margin-top: 1rem; width: 100%; justify-content: center; font-size: 0.85rem; padding: 0.6rem; border-radius: var(--radius-md); border:none; cursor:pointer;"
                    id="topup-studio-btn">Top-up Pack</button>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- ── Footer ───────────────────────────────────────────────── -->
    <%- include('partials/footer') %>

      <script>
        let currentCustomer = null;

        async function lookupCustomer() {
          const query = document.getElementById('topup-query').value.trim();
          const btn = document.getElementById('lookup-submit');

          if (!query) {
            showToast("Please enter your LiteLLM key", true);
            return;
          }

          btn.disabled = true;
          btn.textContent = 'Searching...';

          try {
            const res = await fetch('/api/topup-info', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ query })
            });
            const data = await res.json();

            if (data.error) {
              showToast(data.error, true);
            } else {
              currentCustomer = data;
              document.getElementById('customer-balance').innerText = data.available_budget + ' seconds';
              document.getElementById('lookup-section').style.display = 'none';
              document.getElementById('topup-plans').style.display = 'block';
            }
          } catch (err) {
            showToast("Network error. Try again.", true);
          }

          btn.disabled = false;
          btn.textContent = 'Find Account';
        }

        async function handleTopupBtn(paymentLinkId) {
          if (!currentCustomer || !currentCustomer.stripeId) return;
          if (!paymentLinkId || paymentLinkId === '#') {
            showToast("Payment link not configured.", true);
            return;
          }

          showToast("Preparing checkout...", false);

          try {
            const checkoutReq = await fetch('/api/checkout-topup', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({
                paymentLinkId: paymentLinkId,
                customerId: currentCustomer.stripeId
              })
            });

            const checkoutData = await checkoutReq.json();
            if (checkoutData.url) {
              window.location.href = checkoutData.url;
            } else {
              showToast("Could not initiate checkout: " + (checkoutData.error || "Unknown"), true);
            }
          } catch (e) {
            showToast("Network error. Try again.", true);
          }
        }

        async function downloadPlugin() {
          if (!currentCustomer || !currentCustomer.key) return;
          
          const btn = document.getElementById('download-plugin-btn');
          const originalContent = btn.innerHTML;
          
          btn.disabled = true;
          btn.innerHTML = 'Generating...';

          try {
            const res = await fetch('/api/generate-plugin', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ key: currentCustomer.key })
            });
            const data = await res.json();

            if (data.url) {
              const link = document.createElement('a');
              link.href = data.url;
              link.download = '';
              document.body.appendChild(link);
              link.click();
              document.body.removeChild(link);
              showToast("Download started", false);
            } else {
              showToast(data.error || "Failed to generate plugin", true);
            }
          } catch (err) {
            showToast("Network error. Try again.", true);
          }

          btn.disabled = false;
          btn.innerHTML = originalContent;
        }

        // Auto-lookup if 'key' query parameter is present
        document.addEventListener('DOMContentLoaded', () => {
          const urlParams = new URLSearchParams(window.location.search);
          const keyParam = urlParams.get('key');
          if (keyParam) {
            document.getElementById('topup-query').value = keyParam;
            lookupCustomer();

            // Remove the 'key' from the URL without reloading the page
            urlParams.delete('key');
            const newUrl = window.location.pathname + (urlParams.toString() ? '?' + urlParams.toString() : '');
            window.history.replaceState({}, document.title, newUrl);
          }
        });
      </script>
</body>

</html>