# --- SERVER SETTINGS ---
PORT=3000
BASE_URL=https://your-worker.com # Your actual worker domain

# --- STRIPE CREDENTIALS ---
# Found in Stripe Dashboard > Developers > API Keys
STRIPE_SECRET_KEY=sk_test_51P... 

# Found in Stripe Dashboard > Developers > Webhooks (after creating your endpoint)
STRIPE_WEBHOOK_SECRET=whsec_...

# --- LITELLM CREDENTIALS ---
# The URL where your LiteLLM instance is hosted (e.g., Coolify URL)
LITELLM_URL=https://api.yourdomain.com

# The master key you defined in your LiteLLM config.yaml
LITELLM_MASTER_KEY=sk-master-key-1234

# --- STRIPE PRICING TABLE ---
# Found in Stripe Dashboard > Products > Pricing tables
STRIPE_PRICING_TABLE_ID=prctbl_...

# Found in Stripe Dashboard > Developers > API Keys (Publishable key)
STRIPE_PUBLISHABLE_KEY=pk_test_51P...

# --- PAYMENT LINKS ---
STRIPE_LINK_STARTER=https://buy.stripe.com/test_starter
STRIPE_LINK_LITE=https://buy.stripe.com/test_lite
STRIPE_LINK_CREATOR=https://buy.stripe.com/test_creator
STRIPE_LINK_STUDIO=https://buy.stripe.com/test_studio