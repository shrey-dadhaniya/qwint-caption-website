# --- SERVER SETTINGS ---
PORT=3000
BASE_URL=https://your-worker.com

# --- RAZORPAY CREDENTIALS ---
# Found in Razorpay Dashboard > Settings > API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxx
# Use a dedicated webhook secret from Razorpay Dashboard > Webhooks
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxx

# --- LITELLM CREDENTIALS ---
# The URL where your LiteLLM instance is hosted
LITELLM_URL=https://api.yourdomain.com

# The master key you defined in your LiteLLM config.yaml
LITELLM_MASTER_KEY=sk-master-key-1234
